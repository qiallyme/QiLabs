# =============================================================================
# QiOS Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# =============================================================================
# SUPABASE
# =============================================================================
# Project details from Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_PROJECT_ID=your-project-id-here
SUPABASE_PROJECT_REF=your-project-ref-here
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-database-password-here
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# =============================================================================
# CLOUDFLARE
# =============================================================================
# Workers API tokens and account details
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
CLOUDFLARE_ZONE_ID=your-zone-id-here
CLOUDFLARE_WORKER_NAME=qios-worker
CLOUDFLARE_WORKER_SCRIPT=workers/qios/index.js
CLOUDFLARE_KV_NAMESPACE_ID=your-kv-namespace-id-here
CLOUDFLARE_D1_DATABASE_ID=your-d1-database-id-here
CLOUDFLARE_R2_BUCKET_NAME=qios-assets
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id-here
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key-here
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# =============================================================================
# VITE / FRONTEND
# =============================================================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_API_URL=http://localhost:5173
VITE_APP_ENV=development
VITE_APP_NAME=QiOS

# =============================================================================
# OPENAI
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=org-your-org-id-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# =============================================================================
# GOOGLE GEMINI
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro
GEMINI_EMBEDDING_MODEL=embedding-001

# =============================================================================
# TWILIO
# =============================================================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_API_KEY=your-twilio-api-key-here
TWILIO_API_SECRET=your-twilio-api-secret-here

# =============================================================================
# MCP SERVERS
# =============================================================================
# Zoho MCP
ZOHO_CLIENT_ID=your-zoho-client-id-here
ZOHO_CLIENT_SECRET=your-zoho-client-secret-here
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token-here
ZOHO_ACCESS_TOKEN=your-zoho-access-token-here
ZOHO_ORG_ID=your-zoho-org-id-here
ZOHO_API_DOMAIN=https://www.zohoapis.com

# MCP Server URLs (if running remote MCP servers)
MCP_ZOHO_SERVER_URL=http://localhost:3001
MCP_SERVER_PORT=3001

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
# Direct database connection (if not using Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/qios_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qios_db
DB_USER=postgres
DB_PASSWORD=your-database-password-here
DB_SSL_MODE=require

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
JWT_SECRET=your-jwt-secret-key-here-min-32-chars
SESSION_SECRET=your-session-secret-here
ENCRYPTION_KEY=your-encryption-key-32-chars-min
AUTH_COOKIE_NAME=qios_session
AUTH_COOKIE_DOMAIN=localhost

# =============================================================================
# VECTOR DATABASE (if using separate vector DB)
# =============================================================================
# Pinecone
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=qios-vectors

# Weaviate
WEAVIATE_URL=https://your-cluster.weaviate.network
WEAVIATE_API_KEY=your-weaviate-api-key-here

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key-here

# =============================================================================
# STORAGE
# =============================================================================
# AWS S3 (if using instead of R2)
AWS_ACCESS_KEY_ID=your-aws-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here
AWS_REGION=us-east-1
AWS_S3_BUCKET=qios-assets
AWS_S3_ENDPOINT=https://s3.amazonaws.com

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
SENTRY_DSN=your-sentry-dsn-here
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# EMAIL
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=noreply@qios.local

# Resend (alternative email service)
RESEND_API_KEY=re_your-resend-api-key-here

# =============================================================================
# WEBHOOKS & INTEGRATIONS
# =============================================================================
WEBHOOK_SECRET=your-webhook-secret-here
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret-here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# =============================================================================
# DEVELOPMENT
# =============================================================================
NODE_ENV=development
DEBUG=qios:*
PORT=3000
HOST=localhost
CORS_ORIGIN=http://localhost:5173

# =============================================================================
# PRODUCTION
# =============================================================================
# PRODUCTION_URL=https://qios.yourdomain.com
# PRODUCTION_API_URL=https://api.qios.yourdomain.com

