# --- Timeline Specifics ---
# Ignore the raw source content (unoptimized assets/videos)
# This keeps your repo small and your "Receipts" private if needed
content/

# Ignore Python cache and local virtual environments
__pycache__/
*.py[cod]
*$py.class
.venv/
env/
venv/

# --- Media & Processing ---
# Ignore any temporary ffmpeg files or logs
ffmpeg-*.txt
*.log

# --- Frontend (Vite/Node) ---
node_modules/
dist/
dist-ssr/
*.local

# Editor / System files
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- What we ARE keeping ---
# We do NOT ignore /public/content because those are the
# optimized <25MB files that the site needs to run.
!public/content/
!public/timeline.json