# Cloudflare Worker Environment Variables (Local Development)
# Copy this file to .dev.vars (gitignored) and fill in your values
# For production, use: wrangler secret put <KEY>

# Supabase Configuration (Required)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI Configuration (Required for Gina)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Zoho MCP Integration (Optional)
# Only needed if using Zoho CRM/Projects/Desk integration
ZOHO_MCP_URL=https://qizohomcp-906243217.zohomcp.com/mcp/message
ZOHO_MCP_KEY=your-zoho-mcp-key-here

