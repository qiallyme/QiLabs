{
  "name": "@fcfcu/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./schema": "./schema/index.ts",
    "./schema/*": "./schema/*"
  },
  "scripts": {
    "generate": "bun --bun drizzle-kit generate --config ../drizzle.config.ts",
    "generate:staging": "bun --bun --env ENVIRONMENT=staging drizzle-kit generate --config ../drizzle.config.ts",
    "generate:prod": "bun --bun --env ENVIRONMENT=prod drizzle-kit generate --config ../drizzle.config.ts",
    "migrate": "bun --bun drizzle-kit migrate --config ../drizzle.config.ts",
    "migrate:staging": "bun --bun --env ENVIRONMENT=staging drizzle-kit migrate --config ../drizzle.config.ts",
    "migrate:prod": "bun --bun --env ENVIRONMENT=prod drizzle-kit migrate --config ../drizzle.config.ts",
    "push": "bun --bun drizzle-kit push --config ../drizzle.config.ts",
    "push:staging": "bun --bun --env ENVIRONMENT=staging drizzle-kit push --config ../drizzle.config.ts",
    "push:prod": "bun --bun --env ENVIRONMENT=prod drizzle-kit push --config ../drizzle.config.ts",
    "studio": "bun --bun drizzle-kit studio --config ../drizzle.config.ts",
    "studio:staging": "bun --bun --env ENVIRONMENT=staging drizzle-kit studio --config ../drizzle.config.ts",
    "studio:prod": "bun --bun --env ENVIRONMENT=prod drizzle-kit studio --config ../drizzle.config.ts",
    "seed": "bun scripts/seed.ts",
    "seed:staging": "bun --env ENVIRONMENT=staging scripts/seed.ts",
    "seed:prod": "bun --env ENVIRONMENT=prod scripts/seed.ts",
    "export": "bun scripts/export.ts",
    "export:staging": "bun --env ENVIRONMENT=staging scripts/export.ts",
    "export:prod": "bun --env ENVIRONMENT=prod scripts/export.ts",
    "introspect": "bun --bun drizzle-kit introspect --config ../drizzle.config.ts",
    "up": "bun --bun drizzle-kit up --config ../drizzle.config.ts",
    "check": "bun --bun drizzle-kit check --config ../drizzle.config.ts",
    "drop": "bun --bun drizzle-kit drop --config ../drizzle.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.3",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "drizzle-zod": "^0.8.3",
    "zod": "^4.3.6"
  }
}
