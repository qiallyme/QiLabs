# QiOne Development Environment
# Copy to .env.local and update values as needed

# =============================================================================
# SUPABASE - Required for database connectivity
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# APP CONFIG
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# =============================================================================
# OPTIONAL - For full feature set
# =============================================================================
# CLOUDFLARE_R2_BUCKET_NAME=qios-assets
# MEMORY_WORKER_URL=https://your-worker.workers.dev
