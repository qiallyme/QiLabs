{
  "extends": "./tsconfig-base/node.jsonc",
  "compilerOptions": {
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "types": ["node"]
  },
  "include": ["schema/**/*.ts", "*.ts", "*.json"],
  "exclude": ["**/dist/**/*", "**/node_modules/**/*", "scripts/**/*"]
}

