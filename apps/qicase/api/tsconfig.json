{
  "extends": "./tsconfig-base/cloudflare.jsonc",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "types": [
      "@cloudflare/workers-types"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "**/dist/**/*",
    "**/node_modules/**/*"
  ],
  "references": [
    {
      "path": "../db"
    }
  ]
}