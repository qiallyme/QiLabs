# ═══════════════════════════════════════════════════════════
# Atrium — Environment Variables
# ═══════════════════════════════════════════════════════════
# Only DATABASE_URL and BETTER_AUTH_SECRET are required.
# Everything else has sensible defaults for local development.
# For Docker deployments, see: docs/configuration.md

# ── Required ──────────────────────────────────────────────

DATABASE_URL="postgresql://atrium:atrium@localhost:5432/atrium?schema=public"
BETTER_AUTH_SECRET="change-me-in-production-min-32-chars"

# ── Optional ──────────────────────────────────────────────

# App URLs (auto-detected in Docker; set these for split deployments)
# WEB_URL="http://localhost:3000"
# API_URL="http://localhost:3001"
# BETTER_AUTH_URL="http://localhost:3001"

# Direct DB connection for migrations (bypasses PgBouncer/pooler)
# DIRECT_URL=""

# Storage: local (default) | s3 | minio | r2
# STORAGE_PROVIDER="local"
# UPLOAD_DIR="./uploads"
# S3_ENDPOINT=""
# S3_REGION="us-east-1"
# S3_BUCKET="atrium"
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""

# Email (Resend) — optional, setup wizard handles this if unset
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@yourdomain.com"

# File upload limit
# MAX_FILE_SIZE_MB="50"

# ── Billing (optional) ───────────────────────────────────

# BILLING_ENABLED="false"
# STRIPE_MODE="test"
# STRIPE_TEST_SECRET_KEY=""
# STRIPE_TEST_PUBLISHABLE_KEY=""
# STRIPE_TEST_WEBHOOK_SECRET=""
# STRIPE_TEST_PRO_PRICE_ID=""
# STRIPE_TEST_LIFETIME_PRICE_ID=""
# STRIPE_LIVE_SECRET_KEY=""
# STRIPE_LIVE_PUBLISHABLE_KEY=""
# STRIPE_LIVE_WEBHOOK_SECRET=""
# STRIPE_LIVE_PRO_PRICE_ID=""
# STRIPE_LIVE_LIFETIME_PRICE_ID=""

# ── Analytics / Tracking (optional) ─────────────────────
# JSON array of script tags. Each object's keys become attributes on a <script> tag.
# Supports any tracker (Umami, Plausible, Fathom, etc.) — add as many as you need.
# NEXT_PUBLIC_TRACKERS='[{"src":"https://umami.example.com/script.js","data-website-id":"your-id"}]'

# ── Advanced ──────────────────────────────────────────────

# Skip schema sync on startup (for pooled DB connections that block migrations)
# SKIP_DB_PUSH="false"

# Cookie security flag. Defaults to true in production (NODE_ENV=production).
# Only set to "false" if you are accessing Atrium over plain HTTP with NO
# HTTPS anywhere in the chain (no TLS-terminating reverse proxy).
# WARNING: Disabling secure cookies exposes session tokens to network
# interception. A reverse proxy with HTTPS (Caddy, nginx, Traefik) is
# strongly recommended instead of disabling this.
# SECURE_COOKIES="true"

# Firebase Hosting cookie workaround (only for Firebase CDN deployments)
# FIREBASE_HOSTING="false"

# Rate limiting (requests per minute)
# Raise these for e2e test runs to avoid cascading 429s
# THROTTLE_LIMIT="100"
# SIGNUP_THROTTLE_LIMIT="5"

# LOG_LEVEL="info"
