generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Better Auth tables (managed by Better Auth CLI) ───

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions           Session[]
  accounts           Account[]
  members            Member[]
  projectClients     ProjectClient[]
  documentResponses  DocumentResponse[]
  documentVersions   DocumentVersion[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Organization {
  id             String   @id
  name           String
  slug           String?  @unique
  logo           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  metadata       String?
  setupCompleted Boolean  @default(false)

  members        Member[]
  invitations    Invitation[]
  systemSettings SystemSettings?
  subscription   Subscription?
  labels         Label[]

  @@map("organization")
}

model Member {
  id             String   @id
  organizationId String
  userId         String
  role           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  labels       MemberLabel[]

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id               String    @id
  organizationId   String
  email            String
  role             String?
  status           String
  expiresAt        DateTime
  inviterId        String
  createdAt        DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

// ─── Application tables ───

model Project {
  id             String    @id @default(cuid())
  name           String
  description    String?
  status         String    @default("not_started")
  startDate      DateTime?
  endDate        DateTime?
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?

  files     File[]
  clients   ProjectClient[]
  updates   ProjectUpdate[]
  tasks     Task[]
  invoices  Invoice[]
  notes      ProjectNote[]
  documents  Document[]
  activities ActivityLog[]
  labels     ProjectLabel[]

  @@index([organizationId])
  @@map("project")
}

model ProjectClient {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_client")
}

model File {
  id             String   @id @default(cuid())
  filename       String
  storageKey     String
  mimeType       String
  sizeBytes      Int
  projectId      String
  organizationId String
  uploadedById   String
  createdAt      DateTime @default(now())

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  updates          ProjectUpdate[]
  documents        Document[]
  signedDocuments  Document[]        @relation("SignedDocumentFile")
  invoices         Invoice[]         @relation("UploadedInvoiceFile")
  documentVersions DocumentVersion[]
  labels           FileLabel[]

  @@index([projectId])
  @@index([organizationId])
  @@map("file")
}

model ProjectUpdate {
  id                 String   @id @default(cuid())
  content            String
  attachmentKey      String?  @map("image_key")
  attachmentMimeType String?  @map("image_mime_type")
  attachmentName     String?
  fileId             String?
  projectId          String
  organizationId     String
  authorId           String
  createdAt          DateTime @default(now())

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file     File?            @relation(fields: [fileId], references: [id])
  comments Comment[]

  @@index([projectId])
  @@index([organizationId])
  @@map("project_update")
}

model Task {
  id             String    @id @default(cuid())
  title          String
  description    String?
  dueDate        DateTime?
  completed      Boolean   @default(false)
  order          Int       @default(0)
  type           String    @default("checkbox") // "checkbox" | "decision"
  question       String?
  closedAt       DateTime?
  projectId      String
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  options  DecisionOption[]
  votes    DecisionVote[]
  comments Comment[]
  labels   TaskLabel[]

  @@index([projectId])
  @@index([organizationId])
  @@map("task")
}

model DecisionOption {
  id     String @id @default(cuid())
  taskId String
  label  String
  order  Int    @default(0)

  task  Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  votes DecisionVote[]

  @@index([taskId])
  @@map("decision_option")
}

model DecisionVote {
  id        String   @id @default(cuid())
  optionId  String
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  option DecisionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  task   Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([optionId])
  @@map("decision_vote")
}

model Comment {
  id             String   @id @default(cuid())
  content        String
  authorId       String
  organizationId String
  updateId       String?
  taskId         String?
  createdAt      DateTime @default(now())

  update ProjectUpdate? @relation(fields: [updateId], references: [id], onDelete: Cascade)
  task   Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([updateId])
  @@index([taskId])
  @@index([organizationId])
  @@map("comment")
}

model Invoice {
  id             String            @id @default(cuid())
  invoiceNumber  String
  status         String            @default("draft")
  type           String            @default("itemized") // "itemized" | "uploaded"
  dueDate        DateTime?
  notes          String?
  amount         Int?              // Total in cents, used for uploaded invoices
  uploadedFileId String?
  projectId      String?
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  project      Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  uploadedFile File?             @relation("UploadedInvoiceFile", fields: [uploadedFileId], references: [id])
  lineItems    InvoiceLineItem[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([projectId])
  @@map("invoice")
}

model InvoiceLineItem {
  id          String @id @default(cuid())
  description String
  quantity    Int    @default(1)
  unitPrice   Int   // cents (1500 = $15.00)
  invoiceId   String

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_item")
}

model ProjectNote {
  id             String   @id @default(cuid())
  content        String
  projectId      String
  organizationId String
  authorId       String
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([organizationId])
  @@map("project_note")
}

model ClientProfile {
  id             String  @id @default(cuid())
  userId         String
  organizationId String
  company        String?
  phone          String?
  address        String?
  website        String?
  description    String?

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("client_profile")
}

model Branding {
  id             String   @id @default(cuid())
  organizationId String   @unique
  logoUrl        String?
  logoKey        String?
  primaryColor   String   @default("#2563eb")
  accentColor    String   @default("#f59e0b")
  hideLogo       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("branding")
}

model SystemSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Email settings
  emailProvider  String?  // "resend" | "smtp" | null (disabled)
  emailFrom      String?  // sender address
  resendApiKey   String?  // encrypted
  smtpHost       String?
  smtpPort       Int?
  smtpUser       String?
  smtpPass       String?  // encrypted
  smtpSecure     Boolean  @default(true)

  // Payment settings
  paymentInstructions String?  // Displayed on invoices in the portal
  paymentMethod       String?  // "bank_transfer", "paypal", "stripe_link", "other"
  paymentDetails      String?  // Encrypted — bank account, PayPal email, etc.

  // File settings
  maxFileSizeMb  Int      @default(50)

  // Push notification settings
  vapidPublicKey  String?  // encrypted, auto-generated
  vapidPrivateKey String?  // encrypted, auto-generated

  // General
  setupCompleted Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("system_settings")
}

model ProjectStatus {
  id             String   @id @default(cuid())
  name           String
  slug           String
  order          Int
  color          String   @default("#6b7280")
  organizationId String
  createdAt      DateTime @default(now())

  @@unique([organizationId, name])
  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("project_status")
}

// ─── Documents ───

model Document {
  id                   String    @id @default(cuid())
  type                 String    // "quote", "contract", "nda", "other"
  title                String
  fileId               String
  projectId            String
  organizationId       String
  uploadedById         String
  status               String    @default("draft") // "draft", "pending", "accepted", "declined", "acknowledged", "signed", "voided", "expired"
  requiresSignature    Boolean   @default(false)
  requiresApproval     Boolean   @default(false)
  signedFileId         String?
  sentAt               DateTime?
  voidedAt             DateTime?
  voidedById           String?
  voidReason           String?
  expiresAt            DateTime?
  reminderEnabled      Boolean   @default(false)
  reminderIntervalDays Int       @default(3)
  lastReminderAt       DateTime?
  signingOrderEnabled  Boolean   @default(false)
  options              String?   // comma-separated choices for client selection
  currentVersion       Int       @default(1)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  file            File                @relation(fields: [fileId], references: [id], onDelete: Cascade)
  signedFile      File?               @relation("SignedDocumentFile", fields: [signedFileId], references: [id])
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  responses       DocumentResponse[]
  signatureFields SignatureField[]
  auditEvents     DocumentAuditEvent[]
  accessTokens    DocumentAccessToken[]
  versions        DocumentVersion[]

  @@index([projectId])
  @@index([organizationId])
  @@map("document")
}

model DocumentVersion {
  id           String   @id @default(cuid())
  documentId   String
  fileId       String
  version      Int
  uploadedById String
  note         String?
  createdAt    DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  file       File     @relation(fields: [fileId], references: [id])
  uploadedBy User     @relation(fields: [uploadedById], references: [id])

  @@index([documentId])
  @@map("document_version")
}

model DocumentResponse {
  id                String    @id @default(cuid())
  documentId        String
  userId            String
  action            String    // "accepted", "declined", "acknowledged", "signed"
  reason            String?
  ipAddress         String?
  userAgent         String?
  signatureImageKey String?   // storage key for raw signature PNG
  signatureMethod   String?   // "draw" or "type"
  signedAt          DateTime? // explicit signing timestamp
  fieldId           String?   // which SignatureField was signed
  textValue         String?   // for text/date field values
  createdAt         DateTime  @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId, fieldId])
  @@map("document_response")
}

model SignatureField {
  id          String  @id @default(cuid())
  documentId  String
  pageNumber  Int     // 0-indexed page
  x           Float   // normalized 0-1 (left edge)
  y           Float   // normalized 0-1 (top edge)
  width       Float   // normalized 0-1
  height      Float   // normalized 0-1
  type        String  @default("signature") // "signature", "date", "initials", "text"
  label       String?
  required    Boolean @default(true)
  signerOrder Int     @default(0) // 0 = any order, 1/2/3 = sequential
  assignedTo  String? // specific userId

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("signature_field")
}

model DocumentAuditEvent {
  id         String   @id @default(cuid())
  documentId String
  userId     String?
  action     String   // "created","sent","viewed","signed","accepted","declined","voided","expired","reminder_sent","downloaded"
  ipAddress  String?
  userAgent  String?
  metadata   String?  // JSON
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
  @@map("document_audit_event")
}

model DocumentAccessToken {
  id         String    @id @default(cuid())
  documentId String
  userId     String
  token      String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("document_access_token")
}

// ─── Billing / Subscription tables ───

model SubscriptionPlan {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  stripePriceId  String?
  priceMonthly   Int      @default(0)    // cents
  priceYearly    Int      @default(0)    // cents
  priceLifetime  Int      @default(0)    // cents
  maxProjects    Int      @default(-1)   // -1 = unlimited
  maxStorageMb   Int      @default(-1)
  maxMembers     Int      @default(-1)
  maxClients     Int      @default(-1)
  maxSeats       Int      @default(-1)   // cap on total subscriptions for this plan
  isRecurring    Boolean  @default(true)
  features       String[] @default([])
  description    String?
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions Subscription[]

  @@map("subscription_plan")
}

model Subscription {
  id                     String    @id @default(cuid())
  organizationId         String    @unique
  planId                 String
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?
  stripePaymentIntentId  String?
  status                 String    @default("active") // active, past_due, canceled, incomplete
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([planId])
  @@map("subscription")
}

model Notification {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  type           String   // project_update, comment, task_created, etc.
  title          String
  message        String
  link           String?  // relative URL e.g. "/portal/projects/abc"
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId, organizationId, read])
  @@index([userId, createdAt])
  @@map("notification")
}

model PushSubscription {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  endpoint       String
  p256dh         String
  auth           String
  createdAt      DateTime @default(now())

  @@unique([userId, endpoint])
  @@index([userId, organizationId])
  @@map("push_subscription")
}

model ActivityLog {
  id             String   @id @default(cuid())
  type           String   // "document_response" | "decision_vote" | "decision_closed"
  action         String
  actorId        String
  targetId       String
  targetTitle    String
  detail         String?
  projectId      String
  organizationId String
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([organizationId])
  @@map("activity_log")
}

// ─── Labels ───

model Label {
  id             String   @id @default(cuid())
  name           String
  color          String   @default("#6b7280")
  organizationId String
  createdAt      DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectLabels ProjectLabel[]
  taskLabels    TaskLabel[]
  fileLabels    FileLabel[]
  memberLabels  MemberLabel[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("label")
}

model ProjectLabel {
  id        String   @id @default(cuid())
  projectId String
  labelId   String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label   Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([projectId, labelId])
  @@index([labelId])
  @@map("project_label")
}

model TaskLabel {
  id        String   @id @default(cuid())
  taskId    String
  labelId   String
  createdAt DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@index([labelId])
  @@map("task_label")
}

model FileLabel {
  id        String   @id @default(cuid())
  fileId    String
  labelId   String
  createdAt DateTime @default(now())

  file  File  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([fileId, labelId])
  @@index([labelId])
  @@map("file_label")
}

model MemberLabel {
  id        String   @id @default(cuid())
  memberId  String
  labelId   String
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  label  Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([memberId, labelId])
  @@index([labelId])
  @@map("member_label")
}
