{
  "name": "@atrium/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "bunx prisma generate",
    "db:push": "bunx prisma db push",
    "db:migrate": "bunx prisma migrate dev",
    "db:migrate:deploy": "bunx prisma migrate deploy",
    "db:seed": "bun run src/seed.ts",
    "db:rls": "bun run scripts/apply-rls.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "@atrium/shared": "workspace:*"
  },
  "devDependencies": {
    "prisma": "^6.4.0"
  }
}
