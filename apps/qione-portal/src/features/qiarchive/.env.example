# QiArchive Environment Configuration

# --- Infrastructure ---
PAPERLESS_URL=https://your-paperless-app.up.railway.app
PAPERLESS_API_TOKEN=your_token_here
QIARCHIVE_CLOUD_API_URL=https://qiarchive-api-production.up.railway.app

# --- Agent Buckets (Local / Mounted Drive) ---
QIARCHIVE_INBOX_FOLDER=G:\My Drive\QiArchive\00_INBOX
QIARCHIVE_ARCHIVE_FOLDER=G:\My Drive\QiArchive\10_ARCHIVE_UPLOADED
QIARCHIVE_DUPLICATES_FOLDER=G:\My Drive\QiArchive\20_DUPLICATES
QIARCHIVE_REVIEW_FOLDER=G:\My Drive\QiArchive\30_REVIEW
QIARCHIVE_MANUAL_HOLD_FOLDER=G:\My Drive\QiArchive\40_MANUAL_HOLD
QIARCHIVE_LOG_EXPORTS_FOLDER=G:\My Drive\QiArchive\90_LOG_EXPORTS

# --- Ingestion ---
DOC_ID_PREFIX=QDOC
CURRENT_YEAR=2026
START_ID=1

# --- Manifests ---
MANIFEST_PATH_CSV=./data/90_MANIFESTS/document_manifest.csv
MANIFEST_PATH_JSONL=./data/90_MANIFESTS/document_manifest.jsonl

# --- OCR / Processing ---
DEFAULT_SLUG=misc_document
DEFAULT_DATE=undated

# --- Security ---
SECRET_KEY=generate_a_secure_random_string_here
