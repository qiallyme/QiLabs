{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Document Manifest",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "doc_id",
      "sha256",
      "original_filename",
      "current_filename",
      "status"
    ],
    "properties": {
      "doc_id": { "type": "string", "pattern": "^QDOC-\\d{4}-\\d{6}$" },
      "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
      "original_filename": { "type": "string" },
      "current_filename": { "type": "string" },
      "title": { "type": "string" },
      "slug": { "type": "string" },
      "source": { "type": "string" },
      "status": {
        "enum": ["inbox", "review", "processed", "archived", "duplicate", "quarantine", "error"]
      },
      "duplicate_of": { "type": ["string", "null"] },
      "created_at": { "type": "string", "format": "date-time" },
      "updated_at": { "type": "string", "format": "date-time" }
    }
  }
}
